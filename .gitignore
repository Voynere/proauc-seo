# OS / editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
.tmp_*

# Environment-specific / sensitive files
wp-config.php
.htaccess
error_log

# Runtime logs / archives
logs/
logs_*/
*.log
*.sql
*.gz
*.zip

# Large static dirs (sync from server separately, not in git)
/assets/
/api/

# WordPress runtime and generated content
.tmb/
wp-content/uploads/
wp-content/cache/
wp-content/languages/
wp-content/upgrade/
wp-content/upgrade-temp-backup/
wp-content/advanced-cache.php
wp-content/wp-cache-config.php
wp-content/debug.log
cache/

# Themes: ignore all by default, keep only the custom theme
wp-content/themes/*
!wp-content/themes/index.php
!wp-content/themes/proautospec/

# Plugins: third-party only on this site — not tracked in git
wp-content/plugins/
wp-content/autoptimize_404_handler.php

# WordPress core (not in repo; protects server from accidental git clean)
/index.php
/wp-admin/
/wp-includes/
/wp-*.php
/xmlrpc.php
/readme.html
/license.txt
/.maintenance

# Site root assets and misc (managed on server, not in custom-code repo)
/android-chrome-*.png
/apple-touch-icon.png
/favicon*
/web-app-manifest-*.png
/site.webmanifest
/images/
/robots.txt
/sitemap_*.xml
/rates.json
/get-rates.php
/cf_*.php
/404.html
/google*.html
/yandex_*.html
/.well-known/

# Local SEO workspace (not for GitHub)
/seov/

# Agent RAG index (rebuilt locally)
.cursor/rag/store.sqlite
