<section class="">
    <div class="container py-6">
        <div class="row mb-4">
            <div class="col">
                <h3 class="fw-bolder rfs-9">Color Scheme</h3>
            </div>
        </div>
        <div class="row">
            <div class="col-sm-6 col-lg-4 mb-4">
                <p class="mb-4 d-block border-bottom">Body Colors</p>
                <div class="row row-cols-2 g-4 rfs-4">
                    <div class="text-center hstack gap-2">
                        <div class="pantone_small border border-2 p-3 d-flex flex-column justify-content-center"></div>
                        <span>$body-bg</span>
                    </div>
                    <div class="text-center hstack gap-2">
                        <div style="background-color:var(--bs-body-color)"
                            class="pantone_small border border-2 p-3 d-flex flex-column justify-content-center"></div>
                        <span>$body-color</span>
                    </div>
                    <div class="text-center hstack gap-2">
                        <div style="background-color:var(--bs-link-color)"
                            class="pantone_small border border-2 p-3 d-flex flex-column justify-content-center"></div>
                        <span>($link-color)</span>
                    </div>
                    <div class="text-center hstack gap-2">
                        <div style="background-color:var(--bs-link-hover-color)"
                            class="pantone_small border border-2 p-3 d-flex flex-column justify-content-center"></div>
                        <span>($link-hover-color)</span>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-4 mb-4  ">
                <p class="mb-4 d-block border-bottom">Dark and Light Colors</p>
                <div class="row row-cols-2 g-4 rfs-4">
                    <div class="text-center hstack gap-2">
                        <div
                            class="pantone_small bg-light border border-2 p-3 d-flex flex-column justify-content-center">
                        </div>
                        <span>$light</span>
                    </div>
                    <div class="text-center hstack gap-2">
                        <div
                            class="pantone_small bg-dark border border-2 p-3 d-flex flex-column justify-content-center">
                        </div>
                        <span>$dark</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <p class="mb-4 d-block border-bottom">Theme Colors</p>
                <div class="row row-cols-2 g-4 rfs-4">
                    <div class="text-center hstack gap-2">
                        <div
                            class="pantone_small bg-primary border border-2 p-3 d-flex flex-column justify-content-center">
                        </div>
                        <span>$primary</span>
                    </div>
                    <div class="text-center hstack gap-2">
                        <div
                            class="pantone_small bg-secondary border border-2 p-3 d-flex flex-column justify-content-center">
                        </div>
                        <span>$secondary</span>
                    </div>
                    <div class="text-center hstack gap-2">
                        <div
                            class="pantone_small bg-success border border-2 p-3 d-flex flex-column justify-content-center">
                        </div>
                        <span>$success</span>
                    </div>
                    <div class="text-center hstack gap-2">
                        <div
                            class="pantone_small bg-info border border-2 p-3 d-flex flex-column justify-content-center">
                        </div>
                        <span>$info</span>
                    </div>
                    <div class="text-center hstack gap-2">
                        <div
                            class="pantone_small bg-warning border border-2 p-3 d-flex flex-column justify-content-center">
                        </div>
                        <span>$warning</span>
                    </div>
                    <div class="text-center hstack gap-2">
                        <div
                            class="pantone_small bg-danger border border-2 p-3 d-flex flex-column justify-content-center">
                        </div>
                        <span>$danger</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
