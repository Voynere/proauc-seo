<style>
    * {
        scroll-margin-top: 53px;
    }

    code {
        color: white !important;
    }

    .style_header {
        background-color: var(--bs-primary-text-emphasis);
        color: var(--bs-primary-bg-subtle)
    }

    .pantone_small {
        width: 48px;
        height: 48px;
        border-radius: 0.2rem;

        >p {
            font-size: 0.8rem;
            text-align: center;
            margin-bottom: 0;
        }
    }

    .pantone {
        width: 148px;
        height: 48px;
        border-radius: 0.2rem;

        >p {
            font-size: 0.8rem;
            text-align: center;
            margin-bottom: 0;
        }
    }

    .pantone_shades {
        width: 48px;
        height: 24px;
        border-radius: 0.2rem;
    }

    .mw-48rem {
        max-width: 48rem;
    }

    .style_guide_mono::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: var(--bs-body-bg);
        opacity: 0.2;
        z-index: 2;
    }


    .style_guide_mono_gradient::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: var(--bs-body-bg);
        opacity: 0.8;
        background-image: linear-gradient(to bottom, var(--bs-primary), var(--bs-light));
    }
</style>


<section id="website" class="py-6 bg-body position-relative overflow-hidden">

    <span style="background-color:var(--bs-body-color);color:var(--bs-body-bg)"
        class="badge position-absolute rfs-6 ms-2 top-0 mt-3">$body-bg</span>

    <div class="mx-auto shadow d-flex min-vh-75 row-cols-2" style="max-width:1440px">
        <div class="row border-end border-dark g-0 p-4">
            <div class="lc-block mb-8">
                <h1 class="fs-3 ls-3">BRAND<span style="background-color:var(--bs-body-color);color:var(--bs-body-bg)"
                        class="badge position-absolute rfs-3 ls-0"> $body-color</span></h1>
            </div>
            <div class="col-xxl-7 offset-2 position-relative col-lg-9">
                <h2 class="display-6 mb-4">Use <span class="text-primary position-relative">Primary color<span
                            class="badge position-absolute rfs-3 mt-n2 text-bg-primary">$primary</span></span> to draw
                    attention to important elements <span
                        style="background-color:var(--bs-body-color);color:var(--bs-body-bg)"
                        class="badge position-absolute rfs-3">$body-color</span></h2>
                <p class="text-dark">You can use dark color to draw attention to important elements or to group elements
                    that areconceptually relate <span class="badge position-absolute rfs-3 text-bg-dark">$dark</span>
                </p>

                <p class="">Lorem ipsum dolor sit amet, consectetur adipisicing elit. Possimus voluptate consectetur
                    numquam sint sit quod voluptas vero, <span class="position-relative"><a href="#">This is a link
                            <span style="background-color:var(--bs-link-color)"
                                class="badge position-absolute rfs-3">$link-color</span></a></span><br>
                    Perferendis architecto libero reiciendis saepe qui iure beatae cum.</p>
            </div>
        </div>
        <div class="row bg-body position-relative overflow-hidden g-0"><img class="w-100 position-absolute"
                style="mix-blend-mode: difference; opacity: 0.3; -webkit-filter: grayscale(100%) contrast(100%); filter: grayscale(100%) contrast(100%);"
                src="https://images.unsplash.com/photo-1567359781514-3b964e2b04d6?crop=entropy&amp;cs=tinysrgb&amp;fit=max&amp;fm=jpg&amp;ixid=M3wzNzg0fDB8MXxzZWFyY2h8M3x8YWJzdHJhY3R8ZW58MHwxfHx8MTY5NTc1MzkzNHww&amp;ixlib=rb-4.0.3&amp;q=80&amp;w=1080"
                srcset="https://images.unsplash.com/photo-1567359781514-3b964e2b04d6?crop=entropy&amp;cs=tinysrgb&amp;fit=max&amp;fm=jpg&amp;ixid=M3wzNzg0fDB8MXxzZWFyY2h8M3x8YWJzdHJhY3R8ZW58MHwxfHx8MTY5NTc1MzkzNHww&amp;ixlib=rb-4.0.3&amp;q=80&amp;w=1080 1080w, https://images.unsplash.com/photo-1567359781514-3b964e2b04d6??crop=entropy&amp;cs=tinysrgb&amp;fit=max&amp;fm=jpg&amp;ixid=M3wzNzg0fDB8MXxzZWFyY2h8M3x8YWJzdHJhY3R8ZW58MHwxfHx8MTY5NTc1MzkzNHww&amp;ixlib=rb-4.0.3&amp;q=80&amp;w=150 150w, https://images.unsplash.com/photo-1567359781514-3b964e2b04d6??crop=entropy&amp;cs=tinysrgb&amp;fit=max&amp;fm=jpg&amp;ixid=M3wzNzg0fDB8MXxzZWFyY2h8M3x8YWJzdHJhY3R8ZW58MHwxfHx8MTY5NTc1MzkzNHww&amp;ixlib=rb-4.0.3&amp;q=80&amp;w=300 300w, https://images.unsplash.com/photo-1567359781514-3b964e2b04d6??crop=entropy&amp;cs=tinysrgb&amp;fit=max&amp;fm=jpg&amp;ixid=M3wzNzg0fDB8MXxzZWFyY2h8M3x8YWJzdHJhY3R8ZW58MHwxfHx8MTY5NTc1MzkzNHww&amp;ixlib=rb-4.0.3&amp;q=80&amp;w=768 768w, https://images.unsplash.com/photo-1567359781514-3b964e2b04d6??crop=entropy&amp;cs=tinysrgb&amp;fit=max&amp;fm=jpg&amp;ixid=M3wzNzg0fDB8MXxzZWFyY2h8M3x8YWJzdHJhY3R8ZW58MHwxfHx8MTY5NTc1MzkzNHww&amp;ixlib=rb-4.0.3&amp;q=80&amp;w=1024 1024w"
                sizes="(max-width: 1080px) 100vw, 1080px" width="1080" height="" alt="Photo by Alex Perez">

            <div class="text-center mx-auto pt-7 z-3 position-relative" style="width:17rem">
                <svg style="fill:var(--bs-primary)" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="50" cy="50" r="50"></circle>
                </svg>
                <svg class="position-absolute top-70 start-50 z-n1" style="fill:var(--bs-secondary);width:10rem"
                    viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="50" cy="50" r="50"></circle>
                </svg>

            </div>

            <div class="p-4 mt-6 offset-2 z-2">
                <div class="col-lg-9 col-xl-7 col-xxl-6 mb-4">
                    <h3>Lorem ipsum dolor sit amet, consectetur adipisicing elit.<span
                            style="background-color:var(--bs-body-color);color:var(--bs-body-bg)"
                            class="badge position-absolute rfs-3"> $body-color</span></h3>
                </div>
                <div class="ms-auto col-xxl-6 z-2"><a class="btn btn-primary" href="#">$primary</a>
                    <a class="btn btn-secondary" href="#">$secondary</a>
                </div>
            </div>
        </div>
    </div>
    <div class="mx-auto shadow d-flex min-vh-75 row-cols-2" style="max-width:1440px;">
        <div class="row bg-body position-relative overflow-hidden g-0 min-vh-75">
            <div class="style_guide_mono">
                <img class="opacity-50 w-100 position-absolute start-0 h-100" style="mix-blend-mode:multiply"
                    src="https://images.unsplash.com/photo-1595411425732-e69c1abe2763?crop=entropy&amp;cs=tinysrgb&amp;fit=max&amp;fm=jpg&amp;ixid=M3wzNzg0fDB8MXxzZWFyY2h8MTl8fGFic3RyYWN0fGVufDB8MXx8fDE2OTU3NTQwMTl8MA&amp;ixlib=rb-4.0.3&amp;q=80&amp;w=1080"
                    srcset="https://images.unsplash.com/photo-1595411425732-e69c1abe2763?crop=entropy&amp;cs=tinysrgb&amp;fit=max&amp;fm=jpg&amp;ixid=M3wzNzg0fDB8MXxzZWFyY2h8MTl8fGFic3RyYWN0fGVufDB8MXx8fDE2OTU3NTQwMTl8MA&amp;ixlib=rb-4.0.3&amp;q=80&amp;w=1080 1080w, https://images.unsplash.com/photo-1595411425732-e69c1abe2763??crop=entropy&amp;cs=tinysrgb&amp;fit=max&amp;fm=jpg&amp;ixid=M3wzNzg0fDB8MXxzZWFyY2h8MTl8fGFic3RyYWN0fGVufDB8MXx8fDE2OTU3NTQwMTl8MA&amp;ixlib=rb-4.0.3&amp;q=80&amp;w=150 150w, https://images.unsplash.com/photo-1595411425732-e69c1abe2763??crop=entropy&amp;cs=tinysrgb&amp;fit=max&amp;fm=jpg&amp;ixid=M3wzNzg0fDB8MXxzZWFyY2h8MTl8fGFic3RyYWN0fGVufDB8MXx8fDE2OTU3NTQwMTl8MA&amp;ixlib=rb-4.0.3&amp;q=80&amp;w=300 300w, https://images.unsplash.com/photo-1595411425732-e69c1abe2763??crop=entropy&amp;cs=tinysrgb&amp;fit=max&amp;fm=jpg&amp;ixid=M3wzNzg0fDB8MXxzZWFyY2h8MTl8fGFic3RyYWN0fGVufDB8MXx8fDE2OTU3NTQwMTl8MA&amp;ixlib=rb-4.0.3&amp;q=80&amp;w=768 768w, https://images.unsplash.com/photo-1595411425732-e69c1abe2763??crop=entropy&amp;cs=tinysrgb&amp;fit=max&amp;fm=jpg&amp;ixid=M3wzNzg0fDB8MXxzZWFyY2h8MTl8fGFic3RyYWN0fGVufDB8MXx8fDE2OTU3NTQwMTl8MA&amp;ixlib=rb-4.0.3&amp;q=80&amp;w=1024 1024w"
                    sizes="(max-width: 1080px) 100vw, 1080px" width="1080" height="" alt="Photo by Scott Webb">
            </div>

            <div class="text-center mx-auto align-self-center pt-8 z-2 position-relative" style="width:12rem">
                <svg style="fill:var(--bs-dark)" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="50" cy="50" r="50"></circle>
                </svg>
                <svg class="position-absolute top-70 start-50 z-n1" style="fill:var(--bs-light);width:10rem"
                    viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="50" cy="50" r="50"></circle>
                </svg>
                <span
                    class="badge position-absolute rfs-6 translate-middle start-50 top-70 bg-body text-dark">$dark</span>
                <span class="badge position-absolute rfs-6 start-90 top-100 bg-dark text-light">$light</span>
            </div>

            <div class="align-self-end pb-5 offset-2 z-1">
                <div class="row row-cols-2">
                    <div editable="rich">
                        <h4 class="rfs-12">Lorem ipsum dolor sit amet, consectetur adipisicing elit. Suspendisse a lacus
                            est.</h4>
                    </div>
                    <div class="align-self-end ms-auto ">
                        <a href="#" class="btn btn-primary">$primary</a>
                        <a href="#" class="btn btn-outline-secondary">$secondary</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="row border-end border-dark g-0">

            <div class="position-relative style_guide_mono_gradient mb-5">
                <img class="img-fluid w-100 align-self-start"
                    style="aspect-ratio:16/9;object-fit:cover;object-position:bottom;mix-blend-mode:screen"
                    src="https://images.unsplash.com/photo-1551907234-4f794b152738?crop=entropy&amp;cs=tinysrgb&amp;fit=crop&amp;fm=jpg&amp;ixid=M3wzNzg0fDB8MXxzZWFyY2h8MTEwfHxmdXJuaXR1cmV8ZW58MHwwfHx8MTY5NTc1NjM3Mnww&amp;ixlib=rb-4.0.3&amp;q=80&amp;w=1080&amp;h=768"
                    srcset="https://images.unsplash.com/photo-1551907234-4f794b152738?crop=entropy&amp;cs=tinysrgb&amp;fit=crop&amp;fm=jpg&amp;ixid=M3wzNzg0fDB8MXxzZWFyY2h8MTEwfHxmdXJuaXR1cmV8ZW58MHwwfHx8MTY5NTc1NjM3Mnww&amp;ixlib=rb-4.0.3&amp;q=80&amp;w=1080&amp;h=768 1080w, https://images.unsplash.com/photo-1551907234-4f794b152738??crop=entropy&amp;cs=tinysrgb&amp;fit=crop&amp;fm=jpg&amp;ixid=M3wzNzg0fDB8MXxzZWFyY2h8MTEwfHxmdXJuaXR1cmV8ZW58MHwwfHx8MTY5NTc1NjM3Mnww&amp;ixlib=rb-4.0.3&amp;q=80&amp;w=150 150w, https://images.unsplash.com/photo-1551907234-4f794b152738??crop=entropy&amp;cs=tinysrgb&amp;fit=crop&amp;fm=jpg&amp;ixid=M3wzNzg0fDB8MXxzZWFyY2h8MTEwfHxmdXJuaXR1cmV8ZW58MHwwfHx8MTY5NTc1NjM3Mnww&amp;ixlib=rb-4.0.3&amp;q=80&amp;w=300 300w, https://images.unsplash.com/photo-1551907234-4f794b152738??crop=entropy&amp;cs=tinysrgb&amp;fit=crop&amp;fm=jpg&amp;ixid=M3wzNzg0fDB8MXxzZWFyY2h8MTEwfHxmdXJuaXR1cmV8ZW58MHwwfHx8MTY5NTc1NjM3Mnww&amp;ixlib=rb-4.0.3&amp;q=80&amp;w=768 768w, https://images.unsplash.com/photo-1551907234-4f794b152738??crop=entropy&amp;cs=tinysrgb&amp;fit=crop&amp;fm=jpg&amp;ixid=M3wzNzg0fDB8MXxzZWFyY2h8MTEwfHxmdXJuaXR1cmV8ZW58MHwwfHx8MTY5NTc1NjM3Mnww&amp;ixlib=rb-4.0.3&amp;q=80&amp;w=1024 1024w"
                    sizes="(max-width: 1080px) 100vw, 1080px" width="1080" height="768" alt="Photo by Goashape">

            </div>


            <div class="lc-block px-5 offset-1 pb-6">
                <div class="col-xxl-8" editable="rich">
                    <h2 class="fs-1 mb-4">The quick brown fox jumps over the lazy dog</h2>

                    <span class="badge  rfs-4 "
                        style="background-color:var(--bs-body-color);color:var(--bs-body-bg)">$body-color</span>
                    <span class="badge mb-2 rfs-4 ms-1"
                        style="background-color:var(--bs-body-color);color:var(--bs-body-bg)">.opacity-50</span>
                    <p class="opacity-50 mb-0">I'm body text color with an opacity-50 class.</p>
                    <p class="opacity-50 mb-5">Lorem ipsum dolor sit amet, consectetur adipisicing elit. Laboriosam
                        dolorum dolor quam, ut libero cumque! Nemo eius nulla, iusto libero.
                    </p>


                    <div class="bg-light p-4 position-relative border border-dark">
                        <span class="badge position-xl-absolute rfs-4 bg-dark text-light end-0 me-3 mt-n2">$light</span>
                        <span class="badge rfs-4 text-bg-dark">$dark</span>
                        <p class="text-dark">
                            I'm a <strong>dark</strong> text on a <strong>light</strong> background.<br> dolor sit amet,
                            consectetur adipisicing elit. Optio a numquam nemo vitae commodi, obcaecati reprehenderit ea
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="mx-auto shadow d-flex justify-content-between pt-5" style="max-width:1440px;">
        <div class="lc-block p-5 col-xxl-5">
            <div editable="rich">
                <p class="small text-dark rfs-5"> Copyright notice or something down here. <br>Handcrafted with
                    meticulous attention to detail.
                </p>
            </div>
        </div>
        <div class="lc-block align-self-end p-4 hstack gap-lg-4"><svg xmlns="http://www.w3.org/2000/svg"
                xmlns:xlink="http://www.w3.org/1999/xlink" version="1.1" width="1.3em" height="1.3em"
                viewBox="0 0 24 24" style="" lc-helper="svg-icon" fill="currentColor">
                <path
                    d="M19 3A2 2 0 0 1 21 5V19A2 2 0 0 1 19 21H5A2 2 0 0 1 3 19V5A2 2 0 0 1 5 3H19M18.5 18.5V13.2A3.26 3.26 0 0 0 15.24 9.94C14.39 9.94 13.4 10.46 12.92 11.24V10.13H10.13V18.5H12.92V13.57C12.92 12.8 13.54 12.17 14.31 12.17A1.4 1.4 0 0 1 15.71 13.57V18.5H18.5M6.88 8.56A1.68 1.68 0 0 0 8.56 6.88C8.56 5.95 7.81 5.19 6.88 5.19A1.69 1.69 0 0 0 5.19 6.88C5.19 7.81 5.95 8.56 6.88 8.56M8.27 18.5V10.13H5.5V18.5H8.27Z">
                </path>
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" version="1.1"
                width="1.3em" height="1.3em" viewBox="0 0 24 24" style="" lc-helper="svg-icon" fill="currentColor">
                <path
                    d="M2.6,10.59L8.38,4.8L10.07,6.5C9.83,7.35 10.22,8.28 11,8.73V14.27C10.4,14.61 10,15.26 10,16A2,2 0 0,0 12,18A2,2 0 0,0 14,16C14,15.26 13.6,14.61 13,14.27V9.41L15.07,11.5C15,11.65 15,11.82 15,12A2,2 0 0,0 17,14A2,2 0 0,0 19,12A2,2 0 0,0 17,10C16.82,10 16.65,10 16.5,10.07L13.93,7.5C14.19,6.57 13.71,5.55 12.78,5.16C12.35,5 11.9,4.96 11.5,5.07L9.8,3.38L10.59,2.6C11.37,1.81 12.63,1.81 13.41,2.6L21.4,10.59C22.19,11.37 22.19,12.63 21.4,13.41L13.41,21.4C12.63,22.19 11.37,22.19 10.59,21.4L2.6,13.41C1.81,12.63 1.81,11.37 2.6,10.59Z">
