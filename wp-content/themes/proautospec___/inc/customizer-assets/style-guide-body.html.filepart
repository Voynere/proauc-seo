<section class="py-3">
    <div class="container py-4">
        <div class="row mb-3">
            <div class="col">
                <h3 class="fw-bolder rfs-9">Theme Colors with Shades</h3>
            </div>
        </div>

        <div id="master-colors-primary" class="row p-4 align-items-center border border-primary mb-4">
            <div class="col-12">
                <p class="text-primary h5">Primary Color: <span
                        class="ms-3 text-bg-primary p-3 rfs-4 align-middle rounded"
                        read-scss-var="$primary">#democolor</span></p>
            </div>
            <div class="col-lg-2 offset-xl-1">
                <div class="lc-block">
                    <div class="col mb-4 vstack gap-3">
                        <h6>Text:</h6>
                        <div class="pantone text-primary border p-3 d-flex flex-column justify-content-center">
                            <p class="small ">text-primary</p>
                            <p class="small hex_color mb-0"></p>
                        </div>
                        <div
                            class="pantone text-primary-emphasis  border p-3 d-flex flex-column justify-content-center">
                            <p class="small">text-primary-emphasis </p>
                            <p class="small hex_color mb-0"></p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-2">
                <div class="lc-block">
                    <div class="col mb-4 vstack gap-3">
                        <h6>Background:</h6>
                        <div class="pantone text-bg-primary border p-3 d-flex flex-column justify-content-center">
                            <p class="small ">bg-primary</p>
                            <p class="small hex_color mb-0"></p>
                        </div>
                        <div class="pantone bg-primary-subtle border p-3 d-flex flex-column justify-content-center">
                            <p class="small">bg-primary-subtle </p>
                            <p class="small hex_color mb-0"></p>
                        </div>





                    </div>
                </div>
            </div>
            <div class="col-lg-2">
                <div class="lc-block">
                    <div class="col mb-4 vstack gap-3">
                        <h6>Border:</h6>
                        <div class="pantone border-primary border p-3 d-flex flex-column justify-content-center">
                            <p class="small ">border-primary</p>
                            <p class="small hex_color mb-0"></p>
                        </div>
                        <div class="pantone border-primary-subtle border p-3 d-flex flex-column justify-content-center">
                            <p class="small">border-primary-subtle </p>
                            <p class="small hex_color mb-0"></p>
                        </div>


                    </div>
                </div>
            </div>
            <div class="col offset-xl-1">
                <p class="text-primary fw-bold">Shades:</p>
                <div class="hstack gap-2 mb-2">
                    <div class="pantone_shades bg-primary-25 border d-flex flex-column justify-content-center"
                        title=".bg-primary-25 for background, or .text-primary-25 for text"></div>
                    <div class="pantone_shades bg-primary-50 border d-flex flex-column justify-content-center"></div>
                    <div class="pantone_shades bg-primary-100 border d-flex flex-column justify-content-center"></